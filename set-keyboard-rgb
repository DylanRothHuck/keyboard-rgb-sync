#!/usr/bin/env python3
import os
import sys
import re
import colorsys

HID_PATH = os.environ.get("HID_PATH", "/dev/hidraw4")
sudo_user = os.environ.get("SUDO_USER")
HOME = os.path.expanduser(f"~{sudo_user}") if sudo_user else os.path.expanduser("~")
COLORS_PATH = f"{HOME}/.config/omarchy/current/theme/colors.toml"
KEYBOARD_RGB_PATH = f"{HOME}/.config/omarchy/current/theme/keyboard.rgb"


def parse_hex_color(path):
    with open(path) as f:
        for line in f:
            line = line.strip()
            if not line or line.startswith("#"):
                continue
            m = re.search(r'"(#[0-9a-fA-F]{6})"', line)
            if m:
                return m.group(1)
    return None


def hex_to_hsv255(hex_color):
    r = int(hex_color[1:3], 16) / 255.0
    g = int(hex_color[3:5], 16) / 255.0
    b = int(hex_color[5:7], 16) / 255.0
    h, s, v = colorsys.rgb_to_hsv(r, g, b)
    return int(h * 255), int(s * 255), int(v * 255)


def send_via_cmd(raw_bytes):
    packet = bytes(raw_bytes + [0] * (32 - len(raw_bytes)))
    try:
        with open(HID_PATH, "wb") as f:
            f.write(packet)
    except PermissionError:
        print(f"Permission denied accessing {HID_PATH}. Run with sudo!")
        sys.exit(1)


hex_color = parse_hex_color(COLORS_PATH)
if hex_color is None and os.path.exists(KEYBOARD_RGB_PATH):
    with open(KEYBOARD_RGB_PATH) as f:
        hex_color = f.read().strip()

if hex_color is None or not re.match(r'^#[0-9a-fA-F]{6}$', hex_color):
    print("Could not determine accent color from current theme.")
    sys.exit(1)

hue, sat, val = hex_to_hsv255(hex_color)

print(f"Accent: {hex_color}  →  H={hue} S={sat} V={val}")

print("1. Forcing layout effect to Solid Mode...")
send_via_cmd([0x07, 0x03, 0x02, 1])

print("2. Pushing brightness to maximum...")
send_via_cmd([0x07, 0x03, 0x01, 255])

print("3. Injecting Hue and Saturation from theme accent...")
send_via_cmd([0x07, 0x03, 0x04, hue, sat])

print("Done!")
